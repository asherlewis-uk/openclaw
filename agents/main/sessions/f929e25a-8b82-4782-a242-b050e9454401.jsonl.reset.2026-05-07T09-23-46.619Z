ntainers are on it ===\nforgejo postgres qdrant \n\n=== 1.5 Existing compose stack ===\nservices:\n\n  postgres:\n    image: postgres:16\n    container_name: postgres\n    restart: unless-stopped\n    environment:\n      POSTGRES_USER: hermes\n      POSTGRES_PASSWORD: ***\n      POSTGRES_DB: forgejo\n    volumes:\n      - ./data/postgres:/var/lib/postgresql/data\n    networks:\n      - internal\n\n  forgejo:\n    image: codeberg.org/forgejo/forgejo:10\n    container_name: forgejo\n    restart: unless-stopped\n    depends_on:\n      - postgres\n    environment:\n      - USER_UID=1000\n      - USER_GID=1000\n      - FORGEJO__database__DB_TYPE=postgres\n      - FORGEJO__database__HOST=postgres:5432\n      - FORGEJO__database__NAME=forgejo\n      - FORGEJO__database__USER=hermes\n      - FORGEJO__database__PASSWD=Legion7toolkit!\n    volumes:\n      - ./data/forgejo:/data\n    ports:\n      - \"127.0.0.1:3000:3000\"\n    networks:\n      - internal\n      - web\n\n  qdrant:\n    image: qdrant/qdrant:v1.17\n    container_name: qdrant\n    restart: unless-stopped\n    volumes:\n      - ./data/qdrant:/qdrant/storage\n    ports:\n      - \"127.0.0.1:6333:6333\"\n    networks:\n      - internal\n      - web\n\n  ollama:\n    image: ollama/ollama:0.22.1\n    container_name: ollama\n    restart: unless-stopped\n    deploy:\n      resources:\n        reservations:\n          devices:\n            - driver: nvidia\n              count: 1\n              capabilities: [gpu]\n    volumes:\n      - ./data/ollama:/root/.ollama\n    ports:\n      - \"127.0.0.1:11434:11434\"\n    networks:\n      - internal\n\n  portainer:\n    image: portainer/portainer-ce:2.39.1\n    container_name: portainer\n    restart: unless-stopped\n    volumes:\n      - /var/run/docker.sock:/var/run/docker.sock\n      - ./data/portainer:/data\n    ports:\n      - \"100.106.121.100:9000:9000\"\n    networks:\n      - internal\n\n  caddy:\n    image: caddy:2.11\n    container_name: caddy\n    restart: unless-stopped\n    ports:\n      - \"80:80\"\n      - \"443:443\"\n    volumes:\n      - ./caddy/Caddyfile:/etc/caddy/Caddyfile\n      - ./data/caddy:/data\n      - ./data/caddy-config:/config\n    networks:\n      - internal\n      - web\n\n  cloudflared:\n    image: cloudflare/cloudflared:2026.3.0\n    container_name: cloudflared\n    restart: unless-stopped\n    command: tunnel --no-autoupdate run\n    environment:\n      - TUNNEL_TOKEN=eyJhIj…MSJ9\n    networks:\n      - web\n\nnetworks:\n  internal:\n    driver: bridge\n  web:\n    driver: bridge\n\n=== 1.6 Current Caddyfile ===\ngit.asherlewis.online {\n    reverse_proxy forgejo:3000\n}\n\nqdrant.asherlewis.online {\n    reverse_proxy qdrant:6333\n}\n\nmcp.asherlewis.online {\n    reverse_proxy localhost:8811\n}\n\n=== 1.7 Postgres roles and databases (read-only query) ===\n                             List of roles\n Role name |                         Attributes                         \n-----------+------------------------------------------------------------\n hermes    | Superuser, Create role, Create DB, Replication, Bypass RLS\n udd_app   | \n\n                                                    List of databases\n   Name    |  Owner  | Encoding | Locale Provider |  Collate   |   Ctype    | ICU Locale | ICU Rules | Access privileges \n-----------+---------+----------+-----------------+------------+------------+------------+-----------+-------------------\n forgejo   | hermes  | UTF8     | libc            | en_US.utf8 | en_US.utf8 |            |           | \n postgres  | hermes  | UTF8     | libc            | en_US.utf8 | en_US.utf8 |            |           | \n template0 | hermes  | UTF8     | libc            | en_US.utf8 | en_US.utf8 |            |           | =c/hermes        +\n           |         |          |                 |            |            |            |           | hermes=CTc/hermes\n template1 | hermes  | UTF8     | libc            | en_US.utf8 | en_US.utf8 |            |           | =c/hermes 