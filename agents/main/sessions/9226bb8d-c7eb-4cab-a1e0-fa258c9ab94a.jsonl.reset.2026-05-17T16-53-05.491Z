{"type":"message","id":"7976d943","parentId":"2772f1a3","timestamp":"2026-05-07T00:46:54.422Z","message":{"role":"toolResult","toolCallId":"chatcmpl-tool-ba9c4bb5fee736cd","toolName":"read","content":[{"type":"text","text":"{\n  \"id\": \"kimi-claw\",\n  \"name\": \"kimi-claw\",\n  \"description\": \"Connector plugin that bridges a remote /gateway server with the local OpenClaw Gateway.\",\n  \"version\": \"0.25.2\",\n  \"configSchema\": {\n    \"type\": \"object\",\n    \"additionalProperties\": true,\n    \"properties\": {\n      \"bridge\": {\n        \"type\": \"object\",\n        \"additionalProperties\": true,\n        \"properties\": {\n          \"url\": {\n            \"type\": \"string\"\n          },\n          \"userId\": {\n            \"type\": \"string\"\n          },\n          \"token\": {\n            \"type\": \"string\"\n          },\n          \"kimiapiHost\": {\n            \"type\": \"string\"\n          },\n          \"outboundTransport\": {\n            \"type\": \"string\",\n            \"enum\": [\n              \"im_rpc\",\n              \"bridge_ws\"\n            ]\n          },\n          \"protocol\": {\n            \"type\": \"number\"\n          },\n          \"instanceId\": {\n            \"type\": \"string\"\n          },\n          \"deviceId\": {\n            \"type\": \"string\"\n          },\n          \"forwardThinking\": {\n            \"type\": \"boolean\"\n          },\n          \"forwardToolCalls\": {\n            \"type\": \"boolean\"\n          },\n          \"promptTimeoutMs\": {\n            \"type\": \"number\"\n          },\n          \"historyPendingTimeoutMs\": {\n            \"type\": \"number\"\n          },\n          \"cronSessionTarget\": {\n            \"type\": \"string\",\n            \"enum\": [\n              \"isolated\",\n              \"main\"\n            ]\n          },\n          \"kimiCodeAPIKey\": {\n            \"type\": \"string\"\n          },\n          \"kimiCodeBaseURL\": {\n            \"type\": \"string\"\n          },\n          \"shell\": {\n            \"type\": \"object\",\n            \"additionalProperties\": true,\n            \"properties\": {\n              \"enabled\": {\n                \"type\": \"boolean\"\n              },\n              \"maxConcurrentSessions\": {\n                \"type\": \"number\"\n              },\n              \"idleTimeoutMs\": {\n                \"type\": \"number\"\n              },\n              \"maxDurationMs\": {\n                \"type\": \"number\"\n              },\n              \"defaultShell\": {\n                \"type\": \"string\"\n              }\n            }\n          },\n          \"terminalWs\": {\n            \"type\": \"object\",\n            \"additionalProperties\": true,\n            \"properties\": {\n              \"enabled\": {\n                \"type\": \"boolean\"\n              },\n              \"port\": {\n                \"type\": \"number\"\n              },\n              \"host\": {\n                \"type\": \"string\"\n              },\n              \"path\": {\n                \"type\": \"string\"\n              },\n              \"token\": {\n                \"type\": \"string\"\n              },\n              \"allowedOrigins\": {\n                \"type\": \"array\",\n                \"items\": {\n                  \"type\": \"string\"\n                }\n              }\n            }\n          }\n        }\n      },\n      \"gateway\": {\n        \"type\": \"object\",\n        \"additionalProperties\": true,\n        \"properties\": {\n          \"url\": {\n            \"type\": \"string\"\n          },\n          \"token\": {\n            \"type\": \"string\"\n          },\n          \"protocol\": {\n            \"type\": \"number\"\n          },\n          \"clientId\": {\n            \"type\": \"string\"\n          },\n          \"clientMode\": {\n            \"type\": \"string\"\n          },\n          \"agentId\": {\n            \"type\": \"string\"\n          }\n        }\n      },\n      \"api\": {\n        \"type\": \"object\",\n        \"additionalProperties\": true,\n        \"properties\": {\n          \"baseUrl\": {\n            \"type\": \"string\"\n          },\n          \"token\": {\n            \"type\": \"string\"\n          },\n          \"timeoutMs\": {\n            \"type\": \"number\"\n          }\n        }\n      },\n      \"retry\": {\n        \"type\": \"object\",\n        \"additionalProperties\": true,\n        \"properties\": {\n          \"baseMs\": {\n            \"type\": \"number\"\n          },\n          \"maxMs\": {\n            \"type\": \"number\"\n          },\n          \"maxAttempts\": {\n            \"type\": \"number\"\n          }\n        }\n      },\n      \"log\": {\n        \"type\": \"object\",\n        \"additionalProperties\": true,\n        \"properties\": {\n          \"enabled\": {\n            \"type\": \"boolean\"\n          },\n          \"verbose\": {\n            \"type\": \"boolean\"\n          },\n          \"forwardFile\": {\n            \"type\": \"string\"\n          },\n          \"replyFile\": {\n            \"type\": \"string\"\n          },\n          \"allFile\": {\n            \"type\": \"string\"\n          },\n          \"wsObsFile\": {\n            \"type\": \"string\"\n          },\n          \"requestIdFilter\": {\n            \"type\": \"string\"\n          },\n          \"sessionIdFilter\": {\n            \"type\": \"string\"\n          }\n        }\n      },\n      \"defaultModel\": {\n        \"type\": \"object\",\n        \"additionalProperties\": true,\n        \"properties\": {\n          \"enabled\": {\n            \"type\": \"boolean\"\n          },\n          \"provider\": {\n            \"type\": \"string\"\n          },\n          \"modelId\": {\n            \"type\": \"string\"\n          },\n          \"baseUrl\": {\n            \"type\": \"string\"\n          },\n          \"apiKey\": {\n            \"type\": \"string\"\n         